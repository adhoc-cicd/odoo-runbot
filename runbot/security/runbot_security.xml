<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <record model="ir.module.category" id="module_category_runbot">
        <field name="name">Runbot</field>
        <field name="sequence">0</field>
    </record>
    <record id="runbot.base_runbot_model_access" model="res.groups">
      <field name="name">Runbot model access (public)</field>
    </record>
    <record model="res.groups.privilege" id="runbot_privilege">
      <field name="name">Runbot</field>
      <field name="category_id" ref="module_category_runbot"/>
      <field name="sequence">0</field>
    </record>
    <record id="runbot.group_user" model="res.groups">
      <field name="name">User</field>
      <field name="privilege_id" ref="runbot_privilege"/>
    </record>

    <record id="group_runbot_admin" model="res.groups">
      <field name="name">Runbot administrator</field>
      <field name="privilege_id" ref="runbot_privilege"/>
      <field name="user_ids" eval="[(4, ref('base.user_root'))]"/>
    </record>

    <record id="base.group_public" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('runbot.base_runbot_model_access'))]"/>
    </record>
    <record id="base.group_user" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('runbot.base_runbot_model_access')), (4, ref('runbot.group_user'))]"/>
    </record>
    <record id="base.group_portal" model="res.groups">
      <field name="implied_ids" eval="[(4, ref('runbot.base_runbot_model_access'))]"/>
    </record>
    <record model="res.groups.privilege" id="runbot_privilege_config">
      <field name="name">Config management</field>
      <field name="category_id" ref="module_category_runbot"/>
    </record>
    <record id="group_build_config_user" model="res.groups">
      <field name="name">Build config user</field>
      <field name="privilege_id" ref="runbot_privilege_config"/>
    </record>
    <record id="group_build_config_manager" model="res.groups">
        <field name="name">Build config manager</field>
        <field name="privilege_id" ref="runbot_privilege_config"/>
        <field name="implied_ids" eval="[(4, ref('runbot.group_build_config_user'))]"/>
    </record>
    <record id="group_build_config_administrator" model="res.groups">
        <field name="name">Build config administrator</field>
        <field name="privilege_id" ref="runbot_privilege_config"/>
        <field name="implied_ids" eval="[(4, ref('runbot.group_build_config_manager'))]"/>
        <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>
    <record model="res.groups.privilege" id="runbot_privilege_error">
      <field name="name">Errors</field>
      <field name="category_id" ref="module_category_runbot"/>
    </record>
    <record id="group_runbot_error_manager" model="res.groups">
      <field name="name">Build error manager</field>
      <field name="privilege_id" ref="runbot_privilege_error"/>
      <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>
    <record model="res.groups.privilege" id="runbot_privilege_upgrade_exception">
      <field name="name">Upgrade exceptions</field>
      <field name="category_id" ref="module_category_runbot"/>
    </record>
    <record id="group_runbot_upgrade_exception_manager" model="res.groups">
      <field name="name">Upgrade exception manager</field>
      <field name="privilege_id" ref="runbot_privilege_upgrade_exception"/>
      <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>

    <record model="res.groups.privilege" id="runbot_privilege_codeowner">
      <field name="name">Code Owner</field>
      <field name="category_id" ref="module_category_runbot"/>
    </record>
  
    <record id="group_runbot_codeowner_manager" model="res.groups">
      <field name="name">Code Owner manager</field>
      <field name="privilege_id" ref="runbot_privilege_codeowner"/>
      <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>

    <record model="res.groups.privilege" id="runbot_privilege_bundle">
      <field name="name">Bundle</field>
      <field name="category_id" ref="module_category_runbot"/>
    </record>
  
    <record id="group_runbot_bundle_manager" model="res.groups">
      <field name="name">Bundle manager</field>
      <field name="privilege_id" ref="runbot_privilege_bundle"/>
      <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>

    <record model="res.groups.privilege" id="runbot_privilege_team">
      <field name="name">Team</field>
      <field name="category_id" ref="module_category_runbot"/>
    </record>
  
    <record id="group_runbot_team_manager" model="res.groups">
      <field name="name">Team manager</field>
      <field name="privilege_id" ref="runbot_privilege_team"/>
      <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>


    <record id="group_runbot_advanced_user" model="res.groups">
      <field name="name">Advanced runbot user</field>
      <field name="privilege_id" ref="runbot_privilege"/>
      <field name="implied_by_ids" eval="[(4, ref('runbot.group_runbot_admin'))]"/>
    </record>

    <!-- config access rules-->
    <record id="runbot_build_config_access_administrator" model="ir.rule">
        <field name="name">All config can be edited by config admin</field>
        <field name="groups" eval="[(4, ref('group_build_config_administrator'))]"/>
        <field name="model_id" ref="model_runbot_build_config"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_create" eval="False"/>
    </record>

    <record id="runbot_build_config_access_manager" model="ir.rule">
        <field name="name">Own config can be edited by user</field>
        <field name="groups" eval="[(4, ref('group_build_config_manager'))]"/>
        <field name="model_id" ref="model_runbot_build_config"/>
        <field name="domain_force">[('protected', '=', False)]</field>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_create" eval="True"/>
    </record>

    <record id="runbot_build_config_access_user" model="ir.rule">
        <field name="name">All config can be edited by config admin</field>
        <field name="groups" eval="[(4, ref('group_build_config_user'))]"/>
        <field name="model_id" ref="model_runbot_build_config"/>
        <field name="domain_force">[('create_uid', '=', user.id)]</field>
        <field name="perm_write" eval="True"/>
        <field name="perm_unlink" eval="True"/>
        <field name="perm_read" eval="False"/>
        <field name="perm_create" eval="True"/>
    </record>


    <!-- step access rules-->
    <record id="runbot_build_config_step_access_administrator" model="ir.rule">
        <field name="name">All config step can be edited by config admin</field>
        <field name="groups" eval="[(4, ref('group_build_config_administrator'))]"/>
        <field name="model_id" ref="model_runbot_build_config_step"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read" eval="False"/>
    </record>

    <record id="runbot_build_config_step_access_manager" model="ir.rule">
        <field name="name">Unprotected config step can be edited by manager</field>
        <field name="groups" eval="[(4, ref('group_build_config_manager'))]"/>
        <field name="model_id" ref="model_runbot_build_config_step"/>
        <field name="domain_force">[('protected', '=', False)]</field>
        <field name="perm_read" eval="False"/>
    </record>

    <record id="runbot_build_config_step_access_user" model="ir.rule">
        <field name="name">Own config step can be edited by user</field>
        <field name="groups" eval="[(4, ref('group_build_config_user'))]"/>
        <field name="model_id" ref="model_runbot_build_config_step"/>
        <field name="domain_force">[('protected', '=', False), ('create_uid', '=', user.id)]</field>
        <field name="perm_read" eval="False"/>
    </record>

  </data>
</odoo>

<odoo>
    <data>

    <record id="semgrep_rule_list" model="ir.ui.view">
        <field name="name">runbot.semgrep.rule.tree</field>
        <field name="model">runbot.semgrep_rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" string="Id"/>
                <field name="message"/>
                <field name="category_id"/>
                <field name="language"/>
                <field name="severity"/>
                <field name="min_version_number"/>
                <field name="max_version_number"/>
            </list>
        </field>
    </record>

    <record id="semgrep_rule_form" model="ir.ui.view">
        <field name="name">runbot.semgrep.rule.form</field>
        <field name="model">runbot.semgrep_rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <h1><field name="message" class="w-100"/></h1>
                    <group>
                        <group>
                            <field name="name" string="Code" help="Used to link on wiki"/>
                            <field name="language"/>
                            <field name="severity"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="min_version_number"/>
                            <field name="max_version_number"/>
                        </group>
                    </group>
                    <group string="Patterns">
                        <div colspan="4">
                            <p>
                                You will likely want to write and test rules in <a href="https://semgrep.dev/playground/new?editorMode=advanced">the semgrep playground</a>
                            </p>
                            <p>
                                On the playground, <code># ruleid: {ruleid}</code> can be used to make sure a rule matches a snippet, and <code># ok:{ruleid}</code>
                                to make sure a rule does <i>not</i> match one.
                            </p>
                            <p><a href="https://semgrep.dev/docs/writing-rules/rule-syntax#operators">Pattern Documentation</a></p>
                            <div class="alert alert-warning" role="alert">
                            patterns must include the top-level entry (pattern/pattern-either/...) and be unindented.
                            </div>
                        </div>
                        <group colspan="4">
                            <field name="rule" nolabel="1" colspan="4" widget="ace" options="{'mode': 'python'}"/>
                        </group>
                    </group>
                    <group string="Rendered">
                        <group colspan="4">
                            <field name="rule_text" nolabel="1" colspan="4" widget="ace"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="checker_category_list" model="ir.ui.view">
        <field name="name">runbot.checker.category.tree</field>
        <field name="model">runbot.checker_category</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
            </list>
        </field>
    </record>

    <record id="open_view_semgrep_rule" model="ir.actions.act_window">
        <field name="name">Semgrep Rules</field>
        <field name="res_model">runbot.semgrep_rule</field>
        <field name="view_mode">list,form</field>
        <field name="path">semgrep-rule</field>
    </record>

    <record id="open_view_checker_category" model="ir.actions.act_window">
        <field name="name">Checker Categories</field>
        <field name="res_model">runbot.checker_category</field>
        <field name="view_mode">list,form</field>
        <field name="path">checker-category</field>
    </record>

  </data>
</odoo>

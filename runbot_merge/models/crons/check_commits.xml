<odoo>
    <record id="access_check_commits" model="ir.model.access">
        <field name="name">Access to commits checker is useless</field>
        <field name="model_id" ref="model_runbot_merge_pull_requests_check_commits"/>
        <field name="perm_read">0</field>
        <field name="perm_create">0</field>
        <field name="perm_write">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <record model="ir.cron" id="cron_check_commits">
        <field name="name">Use git to check a PR's commits count (~squash status)</field>
        <field name="model_id" ref="model_runbot_merge_pull_requests_check_commits"/>
        <field name="state">code</field>
        <field name="code">model._run()</field>
        <field name="numbercall">-1</field>
        <field name="doall" eval="False"/>
    </record>
</odoo>

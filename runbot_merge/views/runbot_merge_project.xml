<odoo>
    <record id="runbot_merge_form_project" model="ir.ui.view">
        <field name="name">Project Form</field>
        <field name="model">runbot_merge.project</field>
        <field name="arch" type="xml">
            <form>
                <field name="freeze_id" invisible="1"/>
                <field name="warn_mergiraf" invisible="1"/>
                <div class="alert alert-warning" role="alert"
                     invisible="not warn_mergiraf">
                    Mergiraf is enabled but not available.
                    You should install it on the server.
                </div>
                <header>
                    <button type="object" name="action_prepare_freeze"
                            string="Freeze"
                            invisible="freeze_id"/>
                    <button type="object" name="action_prepare_freeze"
                            string="View Freeze" class="oe_highlight"
                            invisible="not freeze_id"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Name"/></h1>
                    </div>
                    <group col="8">
                        <group colspan="2">
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group colspan="2">
                            <field name="staging_enabled" widget="boolean_toggle"/>
                        </group>
                        <group colspan="2">
                            <field name="github_prefix" string="bot name"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Configuration">
                            <group>
                                <group string="Mergebot">
                                    <field string="token" name="github_token"/>
                                    <field string="name" name="github_name" readonly="0"
                                           help="Identity when creating new commits, defaults to github name, falls back to login."/>
                                    <field name="github_email" readonly="0"
                                           help="Identity when creating new commits, defaults to public email, falls back to primary email."/>
                                </group>
                                <group string="Forwardport">
                                    <field string="token" name="fp_github_token"/>
                                    <field string="name" name="fp_github_name" readonly="0"/>
                                    <field string="Reminder to show after freeze" name="freeze_reminder"/>
                                </group>
                            </group>
                        </page>
                        <page string="Tunables" autofocus="autofocus">
                            <group>
                                <group>
                                    <field name="staging_statuses" string="Validate via GH statuses" widget="boolean_toggle"/>
                                    <field name="ci_timeout"/>
                                    <field name="staging_priority"/>
                                    <field name="batch_limit"/>
                                </group>
                                <group>
                                    <field name="fw_nice" widget="boolean_toggle"/>
                                    <field name="use_mergiraf" widget="boolean_toggle"/>
                                    <field name="lateness_limit"/>
                                    <field name="uniquifier" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </page>
                    </notebook>

                    <separator string="Repositories"/>
                    <field name="repo_ids">
                        <tree>
                            <field name="sequence" widget="handle"/>
                            <button type="object" name="get_formview_action" icon="fa-external-link" title="open repo"/>
                            <field name="name"/>
                            <field name="branch_filter"/>
                            <field name="status_ids" widget="many2many_tags"/>
                            <field string="FP remote" name="fp_remote_target"
                                   help="Repository where forward port branches will be created"
                            />
                        </tree>
                    </field>
                    <separator string="Branches"/>
                    <field name="branch_ids">
                        <tree editable="bottom" decoration-muted="not active">
                            <field name="sequence" widget="handle" />
                            <button type="object" name="get_formview_action" icon="fa-external-link" title="open branch"/>
                            <field name="name"/>
                            <field name="active" widget="boolean_toggle" options="{'autosave': false}"/>
                            <field name="staging_enabled" widget="boolean_toggle" options="{'autosave': false}"/>
                            <field name="depth_first_splits" widget="boolean_toggle" options="{'autosave': false}"/>
                            <field name="presplit" widget="boolean_toggle" options="{'autosave': false}"/>
                            <field name="optimistic_staging_threshold"/>
                            <field name="on_fail"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="project_freeze_reminder" model="ir.ui.view">
        <field name="name">Project Form</field>
        <field name="model">runbot_merge.project</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="freeze_reminder" nolabel="1" readonly="1"/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
